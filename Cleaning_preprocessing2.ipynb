import pandas as pd
import numpy as np
import uuid

df = pd.read_csv('HRDataset_v14.csv')

df = df.drop(columns=['Employee_Name'])
df['EmpID_Hash'] = [uuid.uuid4().hex[:8] for _ in range(len(df))]
df = df.drop(columns=['EmpID'])

df['DateofHire'] = pd.to_datetime(df['DateofHire'], format='%m/%d/%Y', errors='coerce')
df['DateofTermination'] = pd.to_datetime(df['DateofTermination'], format='%m/%d/%y', errors='coerce')
df['LastPerformanceReview_Date'] = pd.to_datetime(df['LastPerformanceReview_Date'], format='%m/%d/%Y', errors='coerce')
df['DOB'] = pd.to_datetime(df['DOB'], format='%m/%d/%y', errors='coerce')

df['DOB'] = df['DOB'].apply(lambda x: x - pd.DateOffset(years=100) if x.year > 2024 else x)

date_extraction = pd.to_datetime('2020-01-01')
df['Date_Calcul'] = df['DateofTermination'].fillna(date_extraction)

df['Age'] = 2024 - df['DOB'].dt.year
bins_age = [18, 30, 40, 50, 60, 100]
labels_age = ['18-30', '31-40', '41-50', '51-60', '60+']
df['Tranche_Age'] = pd.cut(df['Age'], bins=bins_age, labels=labels_age, right=False)

df['Anciennete_Annees'] = (df['Date_Calcul'] - df['DateofHire']).dt.days / 365.25

salaire_moyen_dept = df.groupby('Department')['Salary'].transform('mean')
df['Ratio_Salaire_Dept'] = round(df['Salary'] / salaire_moyen_dept, 2)

df['Projets_Par_Annee'] = np.where(df['Anciennete_Annees'] < 1, 
                                   df['SpecialProjectsCount'], 
                                   round(df['SpecialProjectsCount'] / df['Anciennete_Annees'], 2))

df['Jours_Depuis_Evaluation'] = (df['Date_Calcul'] - df['LastPerformanceReview_Date']).dt.days
df['Jours_Depuis_Evaluation'] = df['Jours_Depuis_Evaluation'].fillna(0)

colonnes_ethiques = ['EmpID_Hash', 'Sex', 'RaceDesc', 'Age', 'Tranche_Age', 'MaritalDesc', 'CitizenDesc', 'HispanicLatino']

df_audit = df[colonnes_ethiques + ['Termd']].copy()
df_audit.to_csv('hr_audit_aif360.csv', index=False)

colonnes_ml = [
    'EmpID_Hash', 'Salary', 'Ratio_Salaire_Dept', 'EngagementSurvey', 'EmpSatisfaction', 
    'SpecialProjectsCount', 'Projets_Par_Annee', 'DaysLateLast30', 
    'Absences', 'PerfScoreID', 'Anciennete_Annees', 'Jours_Depuis_Evaluation', 'Termd'
]

df_ml = df[colonnes_ml].copy()
df_ml = df_ml.dropna()
df_ml.to_csv('hr_ml_features.csv', index=False)
